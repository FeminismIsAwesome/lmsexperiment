<div id="<%= dom_id game %>">
  <% if game.game_type == "memory_match" %>
    <div data-controller="memory-match" 
         data-memory-match-words-value='<%= game.memory_match_words.to_json %>'
         data-memory-match-game-id-value="<%= game.id %>"
         class="game-container">
      
      <p style="color: var(--text-muted); margin-bottom: 2rem;">Match the pairs of words to explore the principles of healthy relationships!</p>
      
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 1rem; margin-top: 2rem;" data-memory-match-target="grid">
        <!-- Cards will be injected by Stimulus -->
      </div>
      
      <div style="margin-top: 3rem; display: flex; justify-content: space-between; align-items: center; background-color: #f8fafc; padding: 1.5rem; border-radius: 0.5rem;">
        <div>
          <p style="margin: 0; font-size: 0.875rem; color: var(--text-muted);">Attempts: <span data-memory-match-target="attempts" style="font-weight: 700; color: var(--text-main);">0</span></p>
          <p data-memory-match-target="status" style="margin: 0.25rem 0 0; font-weight: 700; color: #059669; min-height: 1.5rem;"></p>
        </div>
        <button type="button" class="btn btn-outline" data-action="click->memory-match#reset">Reset Game</button>
      </div>
    </div>
  <% elsif game.game_type == "categorize" %>
    <div data-controller="categorize"
         data-categorize-options-value='<%= game.categorize_options.to_json %>'
         data-categorize-game-id-value="<%= game.id %>"
         class="game-container">
      
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div data-categorize-target="timer" style="font-weight: 700; font-size: 1.25rem;">Time: 30s</div>
        <div data-categorize-target="score" style="font-weight: 700; font-size: 1.25rem;">Score: 0</div>
      </div>

      <div style="text-align: center; margin-bottom: 2rem;">
        <p data-categorize-target="status" style="font-weight: 600; color: var(--text-main); margin-bottom: 1rem;"></p>
        <button type="button" class="btn btn-primary" data-categorize-target="startButton" data-action="click->categorize#startGame">Start Game</button>
      </div>

      <div data-categorize-target="gameArea" style="display: none;">
        <div data-categorize-target="itemCard" style="margin-bottom: 3rem;">
          <!-- Current item will be injected here -->
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;">
          <% (game.categorize_options["categories"] || []).each do |category| %>
            <div class="card category-card" 
                 style="padding: 1.5rem; text-align: center; cursor: pointer; transition: transform 0.1s, background-color 0.2s; background-color: white;"
                 data-action="click->categorize#selectCategory"
                 data-category-id="<%= category["id"] %>"
                 onmouseover="this.style.backgroundColor='#f1f5f9'; this.style.transform='scale(1.02)'"
                 onmouseout="if (this.style.backgroundColor !== 'rgb(220, 252, 231)' && this.style.backgroundColor !== 'rgb(254, 226, 226)') { this.style.backgroundColor='white'; } this.style.transform='scale(1)'">
              <h3 style="margin: 0; font-size: 1.125rem;"><%= category["name"] %></h3>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <div class="card" style="text-align: center; padding: 3rem;">
      <p style="color: var(--text-muted);">This game type (<%= game.game_type %>) is not yet supported.</p>
    </div>
  <% end %>

  <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border-color);">
    <% unless @is_student %>
      <div class="card" style="background-color: #f1f5f9; border-style: dashed; margin-bottom: 2rem;">
        <h3 style="margin-top: 0; font-size: 1rem; margin-bottom: 1rem;">Instructor Analytics</h3>
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; text-align: center;">
          <div>
            <div style="font-size: 1.5rem; font-weight: 700; color: var(--primary-color);"><%= game.unique_starts %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Starts</div>
          </div>
          <div>
            <div style="font-size: 1.5rem; font-weight: 700; color: #059669;"><%= game.unique_completions %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Completions</div>
          </div>
          <div>
            <div style="font-size: 1.5rem; font-weight: 700; color: #d97706;"><%= game.unique_engagements %></div>
            <div style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase;">Deep Engagement</div>
          </div>
        </div>
      </div>
    <% end %>

    <div style="display: flex; justify-content: space-between; align-items: center;">
      <% back_path = @is_student ? student_show_lesson_path(game.lesson) : lesson_path(game.lesson) %>
      <%= link_to "← Back to Lesson", back_path, class: "nav-link", style: "font-size: 0.875rem;" %>
      <% unless @is_student %>
        <%= link_to "Edit Game", edit_game_path(game), class: "nav-link", style: "font-size: 0.875rem;" %>
      <% end %>
    </div>
  </div>
</div>
