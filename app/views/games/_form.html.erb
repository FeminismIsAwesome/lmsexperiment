<%= form_with(model: game) do |form| %>
  <% if game.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(game.errors.count, "error") %> prohibited this game from being saved:</h2>
      <ul>
        <% game.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :lesson_id, style: "display: block" %>
    <%= form.collection_select :lesson_id, Lesson.all, :id, :title %>
  </div>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div data-controller="game-form">
    <div id="game_type_select">
      <%= form.label :game_type, style: "display: block" %>
      <%= form.select :game_type, [["Memory Match", "memory_match"], ["Categorize", "categorize"], ["Emotions", "emotions"]], {}, { 
            data: { action: "change->game-form#toggleFields" }
          } %>
    </div>

    <div id="memory_match_fields" data-game-form-target="memoryMatch">
      <%= form.fields_for :options, OpenStruct.new(game.options || {}) do |options_form| %>
        <div>
          <%= options_form.label :words, "Memory Match Words (comma separated)", style: "display: block" %>
          <%= options_form.text_field :words, value: (game.options&.fetch("words", nil) || Game::DEFAULT_WORDS.join(", ")) %>
        </div>
      <% end %>
    </div>

    <div id="categorize_fields" data-game-form-target="categorize" style="display: none;">
      <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 1rem;">
        The Categorize game defaults to Fruits and Veggies. 
        Advanced configuration will be added in a future update.
      </p>
      
      <%= form.fields_for :options, OpenStruct.new(game.options || {}) do |options_form| %>
        <div>
          <%= options_form.label :time_limit, "Time Limit (seconds)", style: "display: block" %>
          <%= options_form.number_field :time_limit, value: (game.options&.fetch("time_limit", nil) || 30) %>
        </div>
        <div>
          <%= options_form.label :points_per_item, "Points Per Item", style: "display: block" %>
          <%= options_form.number_field :points_per_item, value: (game.options&.fetch("points_per_item", nil) || 1) %>
        </div>
      <% end %>
    </div>
  </div>

  <div style="margin-top: 10px;">
    <%= form.submit %>
  </div>
<% end %>
