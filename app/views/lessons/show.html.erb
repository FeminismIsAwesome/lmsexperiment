<% content_for :title, @lesson.title %>

<div class="lesson-layout">
  <aside class="sidebar">
    <% unless @is_student %>
      <div class="instructor-badge" style="display: block; text-align: center;">
        Instructor Mode
      </div>
    <% end %>

    <div class="sidebar-section">
      <h4 class="sidebar-title"><%= @lesson.title %></h4>
      <div class="nav-group">
        <% @sidebar_items.each do |item| %>
          <% if item.is_a?(Page) %>
            <% active = (@current_page == item) %>
            <% path = @is_student ? student_show_lesson_path(@lesson, page_id: item.id, locale: params[:locale]) : lesson_path(@lesson, page_id: item.id, locale: params[:locale]) %>
            <%= link_to item.translated_title(I18n.locale), path, class: "nav-item #{'active' if active}" %>
          <% elsif item.is_a?(Game) %>
            <% active = (@current_game == item) %>
            <% path = @is_student ? student_show_lesson_path(@lesson, game_id: item.id, locale: params[:locale]) : lesson_path(@lesson, game_id: item.id, locale: params[:locale]) %>
            <%= link_to "🎮 #{item.title}", path, class: "nav-item #{'active' if active}" %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="sidebar-section" style="margin-top: 3rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <% if @is_student %>
          <%= link_to "← Back to all lessons", student_index_lessons_path, class: "nav-item" %>
        <% else %>
          <%= link_to "Add a new page", new_page_path(lesson_id: @lesson.id), class: "btn btn-outline", style: "margin-bottom: 0.5rem;" %>
          <%= link_to "Add a new game", new_game_path(lesson_id: @lesson.id), class: "btn btn-outline", style: "margin-bottom: 0.5rem;" %>
          <%= link_to "Rearrange items", reorder_lesson_path(@lesson), class: "btn btn-outline", style: "margin-bottom: 0.5rem;" %>
          <%= link_to "Edit lesson title", edit_lesson_path(@lesson), class: "nav-link", style: "font-size: 0.875rem;" %>
          <%= link_to "Back to overview", lessons_path, class: "nav-link", style: "font-size: 0.875rem;" %>
          
          <div style="margin-top: 1.5rem;">
            <%= button_to "Destroy Lesson", @lesson, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger", style: "font-size: 0.75rem; padding: 0;" %>
          </div>

          <div class="qr-container" style="margin-top: 2rem;">
            <p style="font-size: 0.75rem; margin-bottom: 0.5rem; font-weight: 600;">Direct Student Link</p>
            <div class="qr-code">
              <%= qr_code_as_svg(student_show_lesson_url(@lesson)) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </aside>

  <main class="main-content">
    <div class="card" style="padding: 2.5rem; min-height: 60vh;">
      <div style="display: flex; justify-content: flex-end; margin-bottom: 1rem; gap: 0.5rem;">
        <% ["en", "es", "fr"].each do |locale| %>
          <% path = @is_student ? student_show_lesson_path(@lesson, page_id: params[:page_id], game_id: params[:game_id], locale: locale) : lesson_path(@lesson, page_id: params[:page_id], game_id: params[:game_id], locale: locale) %>
          <%= link_to locale.upcase, path, class: "btn #{I18n.locale.to_s == locale ? 'btn-primary' : 'btn-outline'}", style: "padding: 0.25rem 0.5rem; font-size: 0.75rem;" %>
        <% end %>
      </div>

      <% if @current_page %>
        <h1 style="margin-top: 0; margin-bottom: 2rem; font-size: 2rem;"><%= @current_page.translated_title(I18n.locale) %></h1>
        <% unless @is_student %>
          <div class="stats-badge" style="background: #f1f5f9; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 1.5rem; font-size: 0.875rem; display: flex; gap: 1.5rem;">
            <span><strong>Unique Visits:</strong> <%= @current_page.unique_visits %></span>
          </div>
        <% end %>
        <%= render @current_page %>
      <% elsif @current_game %>
        <h1 style="margin-top: 0; margin-bottom: 2rem; font-size: 2rem;"><%= @current_game.title %></h1>
        <% unless @is_student %>
          <div class="stats-badge" style="background: #f1f5f9; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 1.5rem; font-size: 0.875rem; display: flex; gap: 1.5rem;">
            <span><strong>Visits:</strong> <%= @current_game.unique_visits %></span>
            <span><strong>Starts:</strong> <%= @current_game.unique_starts %></span>
            <span><strong>Engaged:</strong> <%= @current_game.unique_engagements %></span>
            <span><strong>Completed:</strong> <%= @current_game.unique_completions %></span>
          </div>
        <% end %>
        <%= render @current_game %>
      <% else %>
        <div style="text-align: center; color: var(--text-muted); padding-top: 4rem;">
          <p>This lesson doesn't have any content yet.</p>
          <% unless @is_student %>
            <%= link_to "Add the first page", new_page_path(lesson_id: @lesson.id), class: "btn btn-primary" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </main>
</div>
