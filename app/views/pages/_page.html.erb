<div id="<%= dom_id page %>">
  <div class="page-body">
    <%= page.content %>
  </div>

  <% if page.questions.any? %>
    <div class="card" style="margin-top: 4rem; background-color: #f8fafc; border-color: #e2e8f0;">
      <h3 style="margin-top: 0; margin-bottom: 1.5rem; font-size: 1.25rem;">Knowledge Check</h3>
      <% page.questions.each do |question| %>
        <div style="margin-bottom: 2.5rem;">
          <p style="font-weight: 600; margin-bottom: 1rem; font-size: 1.125rem;"><%= question.text %></p>

          <% user_responses = question.question_responses.where(session_hash: session_hash) %>

          <% if user_responses.any? || !@is_student %>
            <div style="background-color: white; border: 1px solid #e2e8f0; border-radius: 0.5rem; padding: 1.25rem;">
              <p style="font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; border-bottom: 1px solid #f1f5f9; padding-bottom: 0.5rem;">
                Total respondents: <strong><%= question.total_respondents %></strong>
              </p>
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <% question.question_options.each do |option| %>
                  <% has_voted = user_responses.exists?(question_option: option) %>
                  <% percentage = question.response_percentage(option) %>
                  <% border_color = has_voted ? 'var(--primary-color)' : '#f1f5f9' %>
                  <% bg_color = has_voted ? '#eff6ff' : 'transparent' %>
                  <% outer_style = "position: relative; padding: 0.75rem; border-radius: 0.375rem; border: 1px solid #{border_color}; background-color: #{bg_color};" %>
                  <div style="<%= outer_style %>">
                    <div style="display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1;">
                      <span style="font-size: 0.9375rem; <%= has_voted ? 'font-weight: 600;' : '' %>">
                        <%= option.text %>
                        <% if has_voted %>
                          <span style="margin-left: 0.5rem; color: var(--primary-color); font-size: 0.75rem;">(Your choice)</span>
                        <% end %>
                      </span>
                      <span style="font-size: 0.875rem; font-weight: 600; color: var(--text-muted);">
                        <%= percentage %>%
                      </span>
                    </div>
                    <% width_style = "width: #{percentage}%;" %>
                    <% bar_style = "position: absolute; top: 0; left: 0; height: 100%; background-color: #f1f5f9; #{width_style} opacity: 0.3; border-radius: 0.375rem;" %>
                    <div style="<%= bar_style %>"></div>
                  </div>
                <% end %>
              </div>
            </div>
          <% else %>
            <%= form_with url: question_responses_path, method: :post do |f| %>
              <%= f.hidden_field :question_id, value: question.id %>
              <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
                <% question.question_options.each do |option| %>
                  <label class="btn btn-outline" style="justify-content: flex-start; text-align: left; padding: 1rem; border-color: #e2e8f0;">
                    <% if question.multiple_answers %>
                      <%= f.check_box "question_option_ids[]", { id: "option_#{option.id}", style: "margin-right: 0.75rem;" }, option.id, nil %>
                    <% else %>
                      <%= f.radio_button :question_option_id, option.id, id: "option_#{option.id}", style: "margin-right: 0.75rem;" %>
                    <% end %>
                    <span style="font-weight: 400;"><%= option.text %></span>
                  </label>
                <% end %>
              </div>
              <%= f.submit "Submit Answer", class: "btn btn-primary", style: "width: 100%;" %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border-color); display: flex; flex-direction: column; gap: 1rem;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <% if page.previous_page %>
          <% prev_path = @is_student ? student_show_lesson_path(page.lesson, page_id: page.previous_page.id) : lesson_path(page.lesson, page_id: page.previous_page.id) %>
          <%= link_to prev_path, class: "btn btn-outline" do %>
            ← Previous: <%= page.previous_page.title %>
          <% end %>
        <% end %>
      </div>

      <div>
        <% if page.next_page %>
          <% next_path = @is_student ? student_show_lesson_path(page.lesson, page_id: page.next_page.id) : lesson_path(page.lesson, page_id: page.next_page.id) %>
          <%= link_to next_path, class: "btn btn-primary" do %>
            Next: <%= page.next_page.title %> →
          <% end %>
        <% end %>
      </div>
    </div>

    <div style="text-align: center; margin-top: 1rem;">
      <% unless @is_student %>
        <%= link_to "Edit this page", edit_page_path(page), class: "nav-link", style: "font-size: 0.875rem;" %>
      <% end %>
    </div>
  </div>
</div>
